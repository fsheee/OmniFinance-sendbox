# OmniFinance Environment Configuration
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env with real API keys to version control
NEXT_PUBLIC_API_URL = https://your-deployed-backend.example.com
# Google Gemini API Key
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration (optional - defaults to ./omnifinance.db)
# DATABASE_PATH=./omnifinance.db

# FastAPI Server Configuration (optional)
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8000

# Next.js Frontend Configuration
# Development mode: npm run dev (runs on port 3000)
# Production mode: npm run build && next start (static export served by FastAPI)
# NEXT_PUBLIC_API_URL=http://localhost:8000
